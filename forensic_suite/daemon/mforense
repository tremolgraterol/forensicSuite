# ──────────────────────────────────────────────
# MAIN
# ──────────────────────────────────────────────
usage() {
    cat << EOF
mforense v${VERSION} — Framework Forense Profesional
Protocolo: ${PROTOCOL} | $(legal_label)

PROFESIONALES:
  config          Configurar datos del perito (GPG, cédula, tribunal)
  cifrar <arch>   Cifrar evidencia con AES-256-CBC
  descifrar <arc> Descifrar evidencia
  firmar <arch>   Firmar cadena de custodia con GPG
  timestamp <arc> Sello de tiempo RFC 3161
  manifest <arch> Generar manifiesto de evidencia
  audit           Ver log forense (hash chain)

FORENSES:
  init <caso>     Iniciar caso forense
  status          Dashboard del caso
  acquire         Adquirir memoria RAM (FASE 1)
  import -f <arc> Importar evidencia con cadena de custodia
  verify          Verificar integridad + firma + timestamp
  transfer -f -o  Transferir custodia
  analyze         Analizar con Volatility (FASE 2)
  investigate     Investigar hallazgos (FASE 3)
  report          Informe pericial (FASE 4)
  cierre [-d] [-a] Cerrar cadena de custodia (disposición final)
  chain           Cadena de custodia
  convert         Convertir formato de dump
  install         Instalar dependencias
  doc             Documentación

FLUJO PROFESIONAL:
  mforense config                          # 1 vez: datos del perito + GPG
  mforense init CASO-001 -f dump.raw      # crear caso con evidencia
  cd CASO-001 && mforense status
  mforense verify                          # verificar + firma + timestamp
  mforense analyze                         # análisis forense
  mforense report                          # informe pericial firmado
  mforense cierre                          # cerrar cadena de custodia
EOF
    exit 0
}

