# ──────────────────────────────────────────────
# CONVERTIR
# ──────────────────────────────────────────────
cmd_convert() {
    local src="$1"
    [ -f "$src" ] || error "Archivo no encontrado: $src"
    local out="${src%.*}_convertido.raw"
    local fmt=$(detect_format "$src")
    log "Formato: $fmt"
    case "$fmt" in
        lime/avml)
            if command -v avml-convert &>/dev/null; then
                avml-convert -i "$src" -o "$out" 2>/dev/null || error "Error"
            else
                dd if="$src" of="$out" bs=4096 skip=1 status=progress 2>/dev/null
            fi ;;
        *) cp "$src" "$out" ;;
    esac
    if [ "${HASH_PARALELO:-no}" = "si" ]; then
        sha256sum "$out" > "${out}.sha256" & pid1=$!
        md5sum "$out" > "${out}.md5" & pid2=$!
        wait $pid1; wait $pid2
        cat "${out}.sha256"
        cat "${out}.md5"
    else
        sha256sum "$out" | tee "${out}.sha256"
        md5sum "$out" | tee "${out}.md5"
    fi
    audit_log "CONVERTIR" "Convertido $src → $out"
}

