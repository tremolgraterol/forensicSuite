cmd_hash() {
    local file="$1"
    local sha256 md5
    sha256=$(sha256sum "$file" 2>/dev/null | cut -d' ' -f1) || sha256="(error)"
    md5=$(md5sum "$file" 2>/dev/null | cut -d' ' -f1) || md5="(error)"
    echo "$sha256|$md5"
}

# ──────────────────────────────────────────────
# CADENA DE CUSTODIA — FORMATO MP
# ──────────────────────────────────────────────
chain_create() {
    local dump="$1"
    local chain_log="${dump}.chain"
    [ -f "$chain_log" ] && return

    local sha256 md5
    if [ -f "${dump}.sha256" ]; then
        sha256=$(cut -d' ' -f1 < "${dump}.sha256")
        md5=$(cut -d' ' -f1 < "${dump}.md5" 2>/dev/null || echo "(pendiente)")
    else
        sha256=$(timeout 30 sha256sum "$dump" 2>/dev/null | cut -d' ' -f1) || sha256="(no calculado — archivo grande)"
        md5=$(timeout 30 md5sum "$dump" 2>/dev/null | cut -d' ' -f1) || md5="(no calculado)"
    fi

    cat > "$chain_log" << CHAINEOF
# ACTA DE CADENA DE CUSTODIA — EVIDENCIA DIGITAL
**Formato:** Manual Único de Cadena de Custodia (MP 2017)
**País legal:** ${PAIS:-internacional}
**Protocolo:** ${PROTOCOL}

## 1. IDENTIFICACIÓN DE LA EVIDENCIA

| Campo | Valor |
|---|---|
| Archivo | $(basename "$dump") |
| SHA256 | \`$sha256\` |
| MD5 | \`$md5\` |
| Tamaño | $(ls -lh "$dump" | awk '{print $5}') |
| Formato | $(detect_format "$dump") |
| Sistema origen | $(hostname) / $(uname -r) |
| Fecha/hora adquisición | $(date -Iseconds) |
| Herramienta | mforense v${VERSION} |

## 2. COLECTOR

| Campo | Valor |
|---|---|
| Nombre | $PERITO_NOMBRE |
| Cédula | ${PERITO_CEDULA:-(no configurada)} |
| Cargo | ${PERITO_TITULO:-(no configurado)} |
| Firma digital | ${dump}.asc |

## 3. TRANSPORTE

| Campo | Valor |
|---|---|
| Medio de almacenamiento | (por especificar) |
| Ruta origen | $(readlink -f "$dump" 2>/dev/null || echo "$dump") |
| Ruta destino | (por especificar) |
| Hash del recolector | (verificado en adquisición) |

## 4. RECEPTOR / ANALISTA

| Campo | Valor |
|---|---|
| Nombre | $PERITO_NOMBRE |
| Cédula | ${PERITO_CEDULA:-(no configurada)} |
| Firma digital | ${dump}.asc |
| Fecha recepción | $(date -Iseconds) |

## 5. TRANSFERENCIAS SUCESIVAS

| # | Fecha | Entrega | Recibe | Motivo | Firma |
|---|---|---|---|---|---|

## 6. DEVOLUCIÓN O DESTRUCCIÓN

| Campo | Valor |
|---|---|
| Fecha | (pendiente) |
| Disposición final | (pendiente) |
| Autorizado por | (pendiente) |

---
*Documento generado por mforense v${VERSION} — ${PERITO_NOMBRE}*
CHAINEOF
    echo "$chain_log"
}

chain_append_transfer() {
    local dump="$1" nuevo_operador="$2" nota="${3:-Transferido}"
    local chain_log="${dump}.chain"
    [ -f "$chain_log" ] || chain_create "$dump" > /dev/null

    local cs
    if [ -f "${dump}.sha256" ]; then
        cs=$(cut -d' ' -f1 < "${dump}.sha256")
    else
        cs=$(timeout 30 sha256sum "$dump" 2>/dev/null | cut -d' ' -f1) || cs="SHA256_NO_CALCULADO"
    fi
    local fecha=$(date -Iseconds)
    local count=0
    count=$(grep -c '^[|] [0-9]' "$chain_log" 2>/dev/null) || count=0
    local num=$(( count + 1 ))

    local entry="| $num | $fecha | $PERITO_NOMBRE | $nuevo_operador | $nota | SHA256: $cs |"
    local tmpf="${chain_log}.tmp"
    while IFS= read -r line; do
        case "$line" in
            "## 6."*) echo "$entry"; echo "$line" ;;
            *) echo "$line" ;;
        esac
    done < "$chain_log" > "$tmpf" && mv "$tmpf" "$chain_log"
}

chain_cierre() {
    local dump="$1" disposicion="${2:-Consumida en peritaje}" autorizado="${3:-$PERITO_NOMBRE}"
    local chain_log="${dump}.chain"
    [ -f "$chain_log" ] || error "No existe cadena de custodia: $chain_log"

    local tmpf="${chain_log}.tmp"
    local fecha_cierre=$(date -Iseconds)
    while IFS= read -r line; do
        case "$line" in
            "| Fecha | (pendiente) |")           echo "| Fecha | $fecha_cierre |" ;;
            "| Disposición final | (pendiente) |") echo "| Disposición final | $disposicion |" ;;
            "| Autorizado por | (pendiente) |")    echo "| Autorizado por | $autorizado |" ;;
            *) echo "$line" ;;
        esac
    done < "$chain_log" > "$tmpf" && mv "$tmpf" "$chain_log"
    gpg_sign_file "$chain_log" || true
    audit_log "CIERRE" "Cadena de custodia cerrada: $dump — $disposicion"
    log "Cadena de custodia cerrada: $disposicion"
}

cmd_chain() {
    local dump="$1"
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"

    local chain_log="${dump}.chain"
    if [ ! -f "$chain_log" ]; then
        warn "No existe cadena de custodia. Creando con formato MP..."
        chain_create "$dump" > /dev/null
    fi

    # Detectar formato: nuevo (Markdown) vs viejo (texto plano)
    if grep -q '^## 1. IDENTIFICACIÓN' "$chain_log" 2>/dev/null; then
        cat "$chain_log"
    else
        echo "=== CADENA DE CUSTODIA (formato anterior) ==="
        echo "⚠ Este formato no cumple el Manual Único del MP."
        echo "   Considere regenerar: rm ${chain_log} && mforense chain $dump"
        echo ""
        cat "$chain_log"
    fi

    local sig="${dump}.asc"
    if [ -f "$sig" ]; then
        echo ""; echo "--- Firma GPG ---"
        gpg --verify "$sig" "$dump" 2>&1 | grep -E "Good|gpg:" | head -1 || echo "  (no verificada)"
    fi
}

cmd_cierre() {
    local dump="" disposicion="Consumida en peritaje" autorizado="$PERITO_NOMBRE"
    local OPTIND=1
    while getopts "d:a:" opt; do
        case "$opt" in
            d) disposicion="$OPTARG" ;;
            a) autorizado="$OPTARG" ;;
        esac
    done
    shift $((OPTIND-1))
    dump=$(resolve_evidence "$@")
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"

    echo "=============================================="
    echo "  CIERRE DE CADENA DE CUSTODIA"
    echo "  Evidencia: $(basename "$dump")"
    echo "  Disposición: $disposicion"
    echo "  Autorizado por: $autorizado"
    echo "=============================================="
    chain_cierre "$dump" "$disposicion" "$autorizado"
}

check_root() {
    [ "$EUID" -eq 0 ] || error "Se requiere ejecución como root. Use: sudo mforense $*"
}

check_lime() {
    [ -f "$LIME_MODULE" ] || error "Módulo LiME no encontrado. Instale: lime-forensics-dkms"
}

verify_integrity() {
    local dump="$1" result=0
    log "Verificando integridad..."
    if [ "${HASH_PARALELO:-no}" = "si" ]; then
        log "Calculando/verificando hashes en paralelo..."
        if [ -f "${dump}.sha256" ] && [ -f "${dump}.md5" ]; then
            sha256sum -c "${dump}.sha256" 2>/dev/null & pid1=$!
            md5sum -c "${dump}.md5" 2>/dev/null & pid2=$!
            wait $pid1; r1=$?
            wait $pid2; r2=$?
            if [ $r1 -eq 0 ]; then log "SHA256: OK"; else warn "SHA256: NO COINCIDE"; result=1; fi
            if [ $r2 -eq 0 ]; then log "MD5: OK"; else warn "MD5: NO COINCIDE"; result=1; fi
        else
            sha256sum "$dump" > "${dump}.sha256" & pid1=$!
            md5sum "$dump" > "${dump}.md5" & pid2=$!
            wait $pid1; wait $pid2
            log "Hashes calculados."
        fi
    else
        if [ -f "${dump}.sha256" ]; then
            sha256sum -c "${dump}.sha256" 2>/dev/null && log "SHA256: OK" || { warn "SHA256: NO COINCIDE"; result=1; }
        else
            log "SHA256: calculando..."
            sha256sum "$dump" | tee "${dump}.sha256"
        fi
        if [ -f "${dump}.md5" ]; then
            md5sum -c "${dump}.md5" 2>/dev/null && log "MD5: OK" || { warn "MD5: NO COINCIDE"; result=1; }
        else
            log "MD5: calculando..."
            md5sum "$dump" | tee "${dump}.md5"
        fi
    fi
    [ $result -eq 0 ] && log "Integridad: ✅ VERIFICADA" || warn "Integridad: ❌ FALLÓ"
    audit_log "VERIFICAR" "Integridad de $dump: $([ $result -eq 0 ] && echo 'OK' || echo 'FALLÓ')"
    return $result
}

# ──────────────────────────────────────────────
# IMPORTAR EVIDENCIA
# ──────────────────────────────────────────────
cmd_import() {
    local src="" orig_sha256="" orig_md5="" remitente="" caso=""
    local OPTIND=1
    while getopts "f:256:md5:r:c:" opt; do
        case "$opt" in
            f) src="$OPTARG" ;; 256) orig_sha256="$OPTARG" ;;
            md5) orig_md5="$OPTARG" ;; r) remitente="$OPTARG" ;; c) caso="$OPTARG" ;;
        esac
    done
    [ -z "$src" ] && error "Uso: import -f dump.raw [-256 sha] [-md5 hash] [-r remitente] [-c caso]"
    [ -f "$src" ] || error "Archivo no encontrado: $src"

    local base_name=$(basename "$src")
    local dst="$PWD/$base_name"
    [ "$(readlink -f "$src")" != "$(readlink -f "$dst")" ] && cp "$src" "$dst"

    echo "=============================================="
    echo "  IMPORTAR EVIDENCIA — CADENA DE CUSTODIA"
    echo "=============================================="
    log "Archivo: $base_name (detect_format "$dst")"

    local current_sha current_md5
    current_sha=$(sha256sum "$dst" | cut -d' ' -f1)
    current_md5=$(md5sum "$dst" | cut -d' ' -f1)

    if [ -n "$orig_sha256" ]; then
        [ "$current_sha" = "$orig_sha256" ] && log "SHA256: ✅ COINCIDE" || warn "SHA256: ❌ NO COINCIDE"
    fi
    if [ -n "$orig_md5" ]; then
        [ "$current_md5" = "$orig_md5" ] && log "MD5: ✅ COINCIDE" || warn "MD5: ❌ NO COINCIDE"
    fi

    echo "$current_sha  $base_name" > "${dst}.sha256"
    echo "$current_md5  $base_name" > "${dst}.md5"

    local chain_log=$(chain_create "$dst")

    cmd_manifest "$dst"
    gpg_sign_file "$chain_log" || true
    audit_log "IMPORTAR" "Importado $base_name desde $remitente"
    log "Importación completada. Use: mforense verify $base_name"
}

# ──────────────────────────────────────────────
# VERIFICAR
# ──────────────────────────────────────────────
cmd_verify() {
    local dump=$(resolve_evidence "$@")
    echo "=============================================="
    echo "  VERIFICACIÓN FORENSE"
    echo "=============================================="
    cmd_chain "$dump"
    echo ""
    verify_integrity "$dump"
    echo ""
    gpg_verify_file "$dump" || true
    echo ""

    local tsr="${dump}.tsr"
    if [ -f "$tsr" ]; then
        log "Sello de tiempo encontrado:"
        openssl ts -reply -in "$tsr" -text 2>/dev/null | grep -E "Time stamp|Policy" || true
    fi
}

# ──────────────────────────────────────────────
# TRANSFERIR CUSTODIA
# ──────────────────────────────────────────────
cmd_transfer() {
    local dump="" nuevo_operador="" nota=""
    local OPTIND=1
    while getopts "f:o:n:" opt; do
        case "$opt" in
            f) dump="$OPTARG" ;; o) nuevo_operador="$OPTARG" ;; n) nota="$OPTARG" ;;
        esac
    done
    [ -z "$dump" ] && dump=$(resolve_evidence 2>/dev/null) || true
    [ -z "$dump" ] && error "Especifique archivo: transfer -f dump.raw -o 'Nuevo Operador'"
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"
    [ -z "$nuevo_operador" ] && error "Debe especificar: -o 'Nuevo Operador'"

    local chain_log="${dump}.chain"
    [ -f "$chain_log" ] || echo "=== REGISTRO DE CADENA DE CUSTODIA ===" > "$chain_log"
    local cs
    if [ -f "${dump}.sha256" ]; then
        cs=$(cut -d' ' -f1 < "${dump}.sha256")
    else
        cs=$(timeout 30 sha256sum "$dump" 2>/dev/null | cut -d' ' -f1) || cs="SHA256_NO_CALCULADO"
    fi

    echo "=== TRANSFERENCIA DE CUSTODIA ==="
    echo "Archivo:    $(basename "$dump")"
    echo "SHA256:     $cs"
    echo "Entrega:    $PERITO_NOMBRE → $nuevo_operador"
    [ -n "$nota" ] && echo "Nota:       $nota"
    echo "Fecha:      $(date -Iseconds)"

    chain_append_transfer "$dump" "$nuevo_operador" "$nota"
    gpg_sign_file "$chain_log" || true
    audit_log "TRANSFERIR" "Custodia transferida a $nuevo_operador: $nota"
}

# ──────────────────────────────────────────────
# STATUS — DASHBOARD
# ──────────────────────────────────────────────
cmd_status() {
    local -a ev; mapfile -t ev < <(detect_evidence)
    local -a halldirs; mapfile -t halldirs < <(find "$PWD" -maxdepth 1 -type d -name "hallazgos_*" -print0 2>/dev/null | xargs -0 -I{} basename {} | sort)

    echo "=============================================="
    echo "  mforense — DASHBOARD DEL CASO"
    echo "  $PWD"
    echo "=============================================="

    echo ""
    echo "--- EVIDENCIA ---"
    if [ ${#ev[@]} -eq 0 ]; then echo "  (sin evidencia en este directorio)"
    else for f in "${ev[@]}"; do
            local fmt size bn origen="adquirido" firma="" estado_chain=""
            fmt=$(detect_format "$f"); size=$(ls -lh "$f" | awk '{print $5}'); bn=$(basename "$f")
            [ -f "${f}.chain" ] && origen="importado"
            [ -f "${f}.asc" ] && firma="🔐 firmado"
            if [ -f "${f}.chain" ] && grep -q '## 1. IDENTIFICACIÓN' "${f}.chain" 2>/dev/null; then
                if grep -q 'Disposición final' "${f}.chain" 2>/dev/null && ! grep -q '(pendiente)' "${f}.chain" 2>/dev/null; then
                    estado_chain="✅ cadena cerrada"
                else
                    estado_chain="📋 cadena abierta"
                fi
            elif [ -f "${f}.chain" ]; then
                estado_chain="⚠ formato anterior"
            fi
            echo "  📄 $bn"
            echo "     $fmt | $size | $origen $firma $estado_chain"
            [ -f "${f}.chain" ] && grep -q '## 5. TRANSFERENCIAS' "${f}.chain" 2>/dev/null && {
                local ultima=$(grep '^| [0-9]' "${f}.chain" | tail -1)
                [ -n "$ultima" ] && echo "     Última transferencia: $ultima"
            }
        done
    fi

    echo ""; echo "--- ANÁLISIS ---"
    [ ${#halldirs[@]} -eq 0 ] && echo "  (sin análisis previos)"
    for d in "${halldirs[@]}"; do
        local nf=$(find "$PWD/$d" -type f 2>/dev/null | wc -l)
        echo "  📁 $d/ ($nf archivos)"
    done

    echo ""; echo "--- PERITO ---"
    echo "  $PERITO_NOMBRE ${PERITO_CEDULA:+($PERITO_CEDULA)}"
    [ -n "$PERITO_GPG_KEY" ] && echo "  GPG: $PERITO_GPG_KEY"

    if [ ${#ev[@]} -gt 0 ]; then
        echo ""; echo "--- ACCIONES ---"
        echo "  mforense verify          # verificar integridad + firma + timestamp"
        echo "  mforense analyze         # análisis forense"
        echo "  mforense report          # informe pericial"
        echo "  mforense cifrar          # cifrar evidencia"
    fi
    echo ""
}

# ──────────────────────────────────────────────
# INIT
# ──────────────────────────────────────────────
cmd_init() {
    local case_name="${1:-CASE-$(date +%Y%m%d)}"
    local import_file=""; local OPTIND=1
    while getopts "f:" opt; do case "$opt" in f) import_file="$OPTARG";; esac; done
    case_name="${!OPTIND:-$case_name}"
    local base="$PWD/$case_name"

    [ -d "$base" ] && { log "El caso ya existe: $base"; return; }

    echo "=============================================="
    echo "  INICIAR CASO FORENSE"
    echo "  Caso: $case_name"
    echo "  Perito: $PERITO_NOMBRE"
    echo "=============================================="
    mkdir -p "$base"/{adquisicion,analisis,hallazgos,informes,evidencia}

    cat > "$base/caso.json" << EOF2
{
  "caso": "$case_name",
  "creado": "$(date -Iseconds)",
  "perito": "$PERITO_NOMBRE",
  "cedula": "$PERITO_CEDULA",
  "pais": "${PAIS:-internacional}",
  "protocolo": "$PROTOCOL",
  "herramienta": "mforense v$VERSION",
  "ley_aplicable": "$(case "${PAIS:-internacional}" in venezuela) echo 'Ley Especial contra Delitos Informáticos (Venezuela) / ISO 27037';; argentina) echo 'Ley 25.326 / Código Procesal Penal Federal / Convenio Budapest';; *) echo 'ISO 27037 / NIST SP 800-86 / RFC 3227';; esac)",
  "evidencia": [],
  "notas": []
}
EOF2

    echo "  $base/"
    echo "  ├── adquisicion/"
    echo "  ├── evidencia/"
    echo "  ├── analisis/"
    echo "  ├── hallazgos/"
    echo "  ├── informes/"
    echo "  └── caso.json"

    if [ -n "$import_file" ] && [ -f "$import_file" ]; then
        cp "$import_file" "$base/evidencia/"
        (cd "$base" && mforense import -f "evidencia/$(basename "$import_file")")
    fi

    audit_log "INIT" "Caso $case_name creado por $PERITO_NOMBRE"
    log "Caso creado: cd $case_name && mforense status"
}

# ──────────────────────────────────────────────
# FIJACIÓN DOCUMENTAL (ISO 27037)
# ──────────────────────────────────────────────
fijacion_documental() {
    local outdir="${EVIDENCE_DIR}/fijacion_$(date +%Y%m%d_%H%M%S)"
    mkdir -p "$outdir"
    echo "=== FIJACIÓN DOCUMENTAL ==="
    echo "  ISO 27037 — Preservación del lugar de los hechos"
    echo "  Directorio: $outdir"
    echo ""

    log "Fijación — Procesos activos..."
    ps aux 2>/dev/null > "$outdir/ps_aux.txt" || echo "(error al capturar procesos)"

    log "Fijación — Conexiones de red..."
    netstat -tulpn 2>/dev/null > "$outdir/netstat.txt" || ss -tulpn 2>/dev/null > "$outdir/netstat.txt" || echo "(error al capturar red)"

    log "Fijación — Módulos del kernel..."
    lsmod > "$outdir/lsmod.txt" 2>/dev/null || true

    log "Fijación — Sistema de archivos..."
    mount > "$outdir/mount.txt" 2>/dev/null || true
    df -h > "$outdir/df.txt" 2>/dev/null || true

    log "Fijación — Variables de entorno..."
    env | sort > "$outdir/env.txt" 2>/dev/null || true

    log "Fijación — Usuarios activos..."
    who > "$outdir/who.txt" 2>/dev/null || true
    w > "$outdir/w.txt" 2>/dev/null || true

    log "Fijación — Tiempo del sistema..."
    timedatectl > "$outdir/timedatectl.txt" 2>/dev/null || date > "$outdir/date.txt"

    cat > "$outdir/README.md" << FIJEOF
# Fijación Documental — ISO 27037

**Fecha:** $(date -Iseconds)
**Operador:** $PERITO_NOMBRE
**Equipo:** $(hostname) / $(uname -r)

## Archivos Capturados

| Archivo | Contenido | Propósito (ISO 27037) |
|---|---|---|
| ps_aux.txt | Procesos activos | Documentar estado del sistema antes de adquirir |
| netstat.txt | Conexiones de red | Documentar comunicaciones activas (orden de volatilidad) |
| lsmod.txt | Módulos del kernel | Documentar posibles rootkits o modificaciones |
| mount.txt | Sistemas de archivos montados | Documentar almacenamiento conectado |
| df.txt | Uso de disco | Documentar capacidad y particiones |
| env.txt | Variables de entorno | Documentar configuración del sistema |
| who.txt / w.txt | Usuarios conectados | Documentar sesiones activas |
| timedatectl.txt | Hora del sistema | Documentar línea de tiempo forense |

*Esta fijación cumple con el paso de "Fijación" del Manual Único de Cadena de Custodia (MP 2017) y el estándar ISO 27037.*
FIJEOF

    log "Fijación completada: $outdir"
    echo "$outdir"
}

# ──────────────────────────────────────────────
# VERIFICAR HASH DEL RECOLECTOR
# ──────────────────────────────────────────────
verificar_recolector() {
    local metodo="$1"
    case "$metodo" in
        avml)
            if [ -x "$AVML_BIN" ]; then
                local real_hash
                real_hash=$(sha256sum "$AVML_BIN" 2>/dev/null | cut -d' ' -f1) || return
                if [ "$real_hash" = "$AVML_SHA256" ]; then
                    log "AVML: hash verificado ✅ ($real_hash)"
                else
                    warn "AVML: hash NO COINCIDE!"
                    warn "  Esperado: $AVML_SHA256"
                    warn "  Real:     $real_hash"
                    warn "  El binario pudo haber sido modificado."
                    echo ""
                    echo -n "  ¿Continuar de todas formas? [s/N] "
                    read -r resp
                    [ "$resp" != "s" ] && [ "$resp" != "S" ] && error "Operación cancelada por seguridad."
                fi
            fi
            ;;
    esac
}

# ──────────────────────────────────────────────
# FASE 1: ADQUISICIÓN
# ──────────────────────────────────────────────
cmd_acquire() {
    local method="lime"
    local case_name="$(date +%Y%m%d_%H%M%S)"
    while [ $# -gt 0 ]; do
        case "$1" in -m) method="$2"; shift 2;; *) case_name="$1"; shift;; esac
    done

    # Guardar original en adquisicion/ si existe (ISO 27037)
    local adq_dir="${EVIDENCE_DIR}/adquisicion"
    local ev_dir="${EVIDENCE_DIR}/evidencia"
    local outfile
    if [ -d "$adq_dir" ]; then
        outfile="${adq_dir}/${case_name}.raw"
    else
        outfile="${EVIDENCE_DIR}/${case_name}.raw"
    fi
    check_root "acquire"

    echo "=============================================="
    echo "  FASE 1: ADQUISICIÓN DE MEMORIA VOLÁTIL"
    echo "  Caso:    $case_name | Método: $method"
    echo "  Perito:  $PERITO_NOMBRE"
    echo "=============================================="
    sysinfo

    # Fijación documental pre-adquisición (ISO 27037)
    fijacion_documental

    # Verificar integridad del recolector
    verificar_recolector "$method"

    case "$method" in
        lime)
            check_lime
            /sbin/insmod "$LIME_MODULE" path="$outfile" format=raw 2>/dev/null || error "Error al cargar LiME"
            /sbin/rmmod lime 2>/dev/null || true ;;
        avml)
            [ -x "$AVML_BIN" ] || error "AVML no instalado"
            $AVML_BIN "$outfile" 2>/dev/null || error "AVML falló" ;;
        *) error "Método: lime o avml" ;;
    esac

    if [ "${HASH_PARALELO:-no}" = "si" ]; then
        log "Calculando hashes en paralelo..."
        sha256sum "$outfile" > "${outfile}.sha256" & pid1=$!
        md5sum "$outfile" > "${outfile}.md5" & pid2=$!
        wait $pid1; wait $pid2
        cat "${outfile}.sha256"
        cat "${outfile}.md5"
    else
        sha256sum "$outfile" | tee "${outfile}.sha256"
        md5sum "$outfile" | tee "${outfile}.md5"
    fi

    local chain_log=$(chain_create "$outfile")

    chown "$SUDO_USER:$(id -gn "$SUDO_USER" 2>/dev/null || echo "$SUDO_USER")" \
        "$outfile" "${outfile}.sha256" "${outfile}.md5" "$chain_log" 2>/dev/null || true

    cmd_manifest "$outfile"
    gpg_sign_file "$chain_log" || true
    cmd_timestamp "$outfile" || true
    audit_log "ADQUIRIR" "Memoria adquirida: $outfile vía $method"

    echo ""; log "=== CADENA DE CUSTODIA INICIAL ==="
    cat "$chain_log"
    echo "========================"

    # Crear copia de trabajo automáticamente si existe evidencia/
    if [ -d "$ev_dir" ] && [ -d "$adq_dir" ]; then
        echo ""
        log "Creando copia de trabajo para análisis..."
        ensure_working_copy "$outfile" > /dev/null
    fi
}

# ──────────────────────────────────────────────
# FASE 2-4: ANÁLISIS, INVESTIGACIÓN, REPORTE
# ──────────────────────────────────────────────
cmd_analyze() {
    local dump=$(resolve_evidence "$@")
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"
    dump=$(ensure_working_copy "$dump")
    mkdir -p "$ANALYSIS_DIR"
    local cname=$(detect_case_name "$dump"); CASE_NAME="$cname"

    echo "=== FASE 2: ANÁLISIS ==="
    echo "Evidencia: $dump ($(ls -lh "$dump" | awk '{print $5}'))"
    echo "Formato:   $(detect_format "$dump") | Caso: $cname"
    cmd_chain "$dump"; verify_integrity "$dump" || true

    echo ""; log "2.1 — SO...";         vol -f "$dump" banners.Banners 2>&1 | tee "$ANALYSIS_DIR/01_sistema.txt" || true
    echo ""; log "2.2 — Procesos...";   vol -f "$dump" linux.pslist.PsList 2>&1 | tee "$ANALYSIS_DIR/02_procesos.txt" || true
    echo ""; log "2.3 — Árbol...";      vol -f "$dump" linux.pstree.PsTree 2>&1 | tee "$ANALYSIS_DIR/03_arbol_procesos.txt" || true
    advertencia_privacidad
    echo ""; log "2.4 — Bash...";       vol -f "$dump" linux.bash.Bash 2>&1 | tee "$ANALYSIS_DIR/04_bash_history.txt" || true
    echo ""; log "2.5 — Argumentos..."; vol -f "$dump" linux.psaux.PsAux 2>&1 | tee "$ANALYSIS_DIR/05_argumentos.txt" || true
    echo ""; log "2.6 — Red...";        vol -f "$dump" linux.netstat 2>&1 | tee "$ANALYSIS_DIR/06_red.txt" || true
    echo ""; log "2.7 — LSOF...";       vol -f "$dump" linux.lsof 2>&1 | tee "$ANALYSIS_DIR/07_archivos_abiertos.txt" || true
    echo ""; log "2.8 — Malfind...";    vol -f "$dump" linux.malfind.Malfind 2>&1 | tee "$ANALYSIS_DIR/08_malfind.txt" || true
    audit_log "ANALIZAR" "Análisis FASE 2 completado: $dump → $ANALYSIS_DIR"
    log "Resultados: $ANALYSIS_DIR/"
}

cmd_investigate() {
    local dump=$(resolve_evidence "$@")
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"
    dump=$(ensure_working_copy "$dump")
    mkdir -p "$ANALYSIS_DIR"
    echo "=== FASE 3: INVESTIGACIÓN ==="

    log "3.1 — Ocultos...";    vol -f "$dump" linux.psscan.PsScan 2>&1 | tee "$ANALYSIS_DIR/09_procesos_ocultos.txt" || true
    echo ""; log "3.2 — Módulos...";  vol -f "$dump" linux.lsmod.LsMod 2>&1 | tee "$ANALYSIS_DIR/10_modulos_kernel.txt" || true
    echo ""; log "3.3 — Maps...";     vol -f "$dump" linux.proc.Maps 2>&1 | head -100 | tee "$ANALYSIS_DIR/11_mapas_memoria.txt" || true
    advertencia_privacidad
    echo ""; log "3.4 — Envars...";   vol -f "$dump" linux.envvars.EnvVars 2>&1 | tee "$ANALYSIS_DIR/12_env_vars.txt" || true
    echo ""; log "3.5 — Inyección..."; vol -f "$dump" linux.malfind.Malfind --dump 2>&1 | tee "$ANALYSIS_DIR/13_inyeccion.txt" || true

    echo ""; log "3.6 — Resumen..."
    {
        echo "=== HALLAZGOS ==="; echo "Fecha: $(date)"; echo "Archivo: $dump"
        echo "Procesos: $(wc -l < "$ANALYSIS_DIR/02_procesos.txt" 2>/dev/null || echo 'N/A')"
        echo "Conexiones: $(grep -ic 'established\|listen' "$ANALYSIS_DIR/06_red.txt" 2>/dev/null || echo 0)"
        echo "Inyecciones: $(grep -c Malfind "$ANALYSIS_DIR/13_inyeccion.txt" 2>/dev/null || echo 0)"
        echo "Archivos tmp: $(grep -c '/tmp\|/dev/shm' "$ANALYSIS_DIR/07_archivos_abiertos.txt" 2>/dev/null || echo 0)"
    } | tee "$ANALYSIS_DIR/17_resumen_hallazgos.txt"
    audit_log "INVESTIGAR" "Investigación FASE 3 completada: $dump"
    log "Hallazgos: $ANALYSIS_DIR/"
}

cmd_report() {
    local dump=$(resolve_evidence "$@")
    [ -f "$dump" ] || error "Archivo no encontrado: $dump"
    dump=$(ensure_working_copy "$dump")
    mkdir -p "$ANALYSIS_DIR"
    local cname=$(detect_case_name "$dump"); CASE_NAME="$cname"
    local sha256 md5
    if [ -f "${dump}.sha256" ]; then
        sha256=$(cut -d' ' -f1 < "${dump}.sha256")
        md5=$(cut -d' ' -f1 < "${dump}.md5" 2>/dev/null || echo "(no calculado)")
    else
        local hashes=$(cmd_hash "$dump")
        sha256=$(echo "$hashes" | cut -d'|' -f1)
        md5=$(echo "$hashes" | cut -d'|' -f2)
    fi
    local report_file="$ANALYSIS_DIR/informe_pericial_${TIMESTAMP}.md"
    local r=$report_file
    local origen=$([ -f "${dump}.chain" ] && echo "importado" || echo "adquirido localmente")

