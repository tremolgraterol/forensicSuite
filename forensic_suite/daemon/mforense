cmd_install() {
    [ "$EUID" -eq 0 ] || error "Ejecutar como root: sudo mforense install"
    echo "=============================================="
    echo "  Instalación mforense v${VERSION}"
    echo "=============================================="
    apt update -qq; apt install -yq lime-forensics-dkms xxd curl dcfldd foremost python3 python3-pip build-essential psmisc file binutils sleuthkit guymager
    pip3 install --break-system-packages -q volatility3 2>/dev/null || pip3 install -q volatility3
    curl -sL -o /usr/local/bin/avml https://github.com/microsoft/avml/releases/download/v0.18.0/avml && chmod +x /usr/local/bin/avml && chown root:root /usr/local/bin/avml
    dkms autoinstall 2>/dev/null || true
    echo "  Instalado. Configure: mforense config"
}

